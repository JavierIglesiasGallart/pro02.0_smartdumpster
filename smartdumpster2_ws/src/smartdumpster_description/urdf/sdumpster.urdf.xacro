<?xml version="1.0"?>


<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="smartdumpster">

    <xacro:arg name="is_ignition" default="True" />

    <xacro:arg name="is_sim" default="True" />

    <!-- Include Gezabo parameters -->
    <xacro:include filename="$(find smartdumpster_description)/urdf/sdumpster_gazebo.xacro" />

    <!-- Include ROS2 Control -->
    <xacro:include filename="$(find smartdumpster_description)/urdf/sdumpster_ros2_control.xacro" />

    <link name="base_footprint" />

    <link name="base_link">

        <inertial>
            <mass value="40.0" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="3.27" ixy="0.0" ixz="0.0"
                     iyy="3.77" iyz="0.0" 
                     izz="3.77" />
        </inertial>
        
        <visual>
            <origin rpy="1.57 0 1.57" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/base_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
            <material name="silver"/>
        </visual>

        <collision>
            <origin rpy="1.57 0 1.57" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/base_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>

    </link>

    <joint name="base_joint" type="fixed">

        <parent link="base_footprint" />
        <child link="base_link" />

        <origin rpy="0 0 0" xyz="0 0 0.1175" />

    </joint>

    <link name="wheel_right_link">

        <inertial>
            <mass value="0.836" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.00397" ixy="0.0" ixz="0.0"
                     iyy="0.00210" iyz="0.0" 
                     izz="0.00210" />
        </inertial>

        <visual>
            <origin rpy="0 0 1.57" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/wheel_right_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <origin rpy="0 0 1.57" xyz="0 -0.015 0" />
            <geometry>
                <sphere radius="0.0975" />
            </geometry>
        </collision>

    </link>

    <joint name="wheel_right_joint" type="continuous">

        <parent link="base_link" />
        <child link="wheel_right_link" />

        <axis xyz="0 1 0" />
        <origin rpy="0 0 0" xyz="0 -0.360 -0.020" />

    </joint>

    <link name="wheel_left_link">

        <inertial>
            <mass value="0.836" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.00397" ixy="0.0" ixz="0.0"
                     iyy="0.00210" iyz="0.0" 
                     izz="0.00210" />
        </inertial>

        <visual>
            <origin rpy="0 0 1.57" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/wheel_left_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <origin rpy="0 0 1.57" xyz="0 0.015 0" />
            <geometry>
                <sphere radius="0.0975" />
            </geometry>
        </collision>

    </link>

    <joint name="wheel_left_joint" type="continuous">

        <parent link="base_link" />
        <child link="wheel_left_link" />

        <axis xyz="0 1 0" />
        <origin rpy="0 0 0" xyz="0 0.360 -0.020" />

    </joint>

    <link name="caster_front_link">

        <inertial>
            <mass value="0.329" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.000306" ixy="0.0" ixz="0.0"
                     iyy="0.000306" iyz="0.0" 
                     izz="0.000306" />
        </inertial>

        <visual>
            <origin rpy="1.57 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/caster_wheel_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <origin rpy="1.57 0 0" xyz="0 0 0" />
            <geometry>
                <sphere radius="0.0965" />
            </geometry>
        </collision>

    </link>

    <joint name="caster_front_joint" type="fixed">

        <parent link="base_link" />
        <child link="caster_front_link" />

        <origin rpy="0 0 0" xyz="0.275 0 -0.021" />

    </joint>

    <link name="caster_rear_link">

        <inertial>
            <mass value="0.329" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.000306" ixy="0.0" ixz="0.0"
                     iyy="0.000306" iyz="0.0" 
                     izz="0.000306" />
        </inertial>

        <visual>
            <origin rpy="1.57 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/caster_wheel_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <origin rpy="1.57 0 0" xyz="0 0 0" />
            <geometry>
                <sphere radius="0.0965" />
            </geometry>
        </collision>

    </link>

    <joint name="caster_rear_joint" type="fixed">

        <parent link="base_link" />
        <child link="caster_rear_link" />

        <origin rpy="0 0 0" xyz="-0.275 0 -0.021" />

    </joint>

    <!-- Laser 2D -->
    <link name="laser_link">

        <inertial>
            <origin xyz="-0.011945780406062 -0.000381929217680526 -0.0170649378129477" rpy="0 0 0" />
            <mass value="0.073084435549317" />
            <inertia ixx="1.96074931730795E-05" ixy="-3.62091076640009E-07" ixz="4.28230084046735E-07" 
                     iyy="2.40983835136327E-05" iyz="1.50180909250652E-08"
                     izz="4.14184164228595E-05" />
        </inertial>
        
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/laser_link.STL" />
            </geometry>
            <material name="dark_grey"/>
        </visual>

        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/laser_link.STL" />
            </geometry>
        </collision>

    </link>

    <joint name="laser_joint" type="fixed">
        
        <parent link="base_link" />
        <child link="laser_link" />

        <axis xyz="0 0 0" />
        <origin xyz="0 0 0.1808" rpy="0 0 3.14" />

    </joint>

    <!-- Zed2i Camera + Sensor Integrated -->
    <xacro:include filename="$(find zed_description)/urdf/zed_macro.urdf.xacro" />

    <xacro:zed_camera name="zed2i" model="zed2i" enable_gnss="false">
        <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:zed_camera>

    <joint name="zed2i_base_joint" type="fixed">
        <parent link="base_link" /> 
        <child link="zed2i_camera_link" /> 
        <origin xyz="0.399 0 0.075" rpy="0 0 0" /> 
    </joint>

    <link name="imu_link">

        <inertial>
            <origin xyz="-0.00552433659106688 0.000168210391520346 0.000514000497342681" rpy="0 0 0" />
            <mass value="0.000528415362211671" />
            <inertia ixx="1.46176048428261E-08" ixy="1.40015117949421E-10" ixz="-1.99633872937403E-12"
                    iyy="8.59662482954888E-09" iyz="7.52375112767959E-12"
                    izz="2.30279421279312E-08" />
        </inertial>
        
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/imu_link.STL" />
            </geometry>
        </visual>

        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/imu_link.STL" />
            </geometry>
        </collision>

    </link>

    <joint name="imu_joint" type="fixed">
        
        <parent link="zed2i_left_camera_frame" />
        <child link="imu_link" />

        <axis xyz="0 0 0" />
        <origin xyz="-0.002 -0.023 0.00022" rpy="-0.004 0.00 -0.008" /> 

    </joint>
    

    <!-- VISUAL MATERIAL COLOR -->
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>
    <material name="silver">
        <color rgba="0.79 0.82 0.93 1"/>
    </material>
    <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1"/>
    </material>

</robot>