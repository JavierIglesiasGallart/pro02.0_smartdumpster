<?xml version="1.0"?>


<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="smartdumpster">

    <xacro:arg name="is_ignition" default="True" />

    <!-- Include Gezabo parameters -->
    <xacro:include filename="$(find smartdumpster_description)/urdf/sdumpster_gazebo.xacro" />

    <!-- Include ROS2 Control -->
    <xacro:include filename="$(find smartdumpster_description)/urdf/sdumpster_ros2_control.xacro" />

    <link name="base_footprint" />

    <link name="base_link">

        <inertial>
            <mass value="40.0" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="3.27" ixy="0.0" ixz="0.0"
                     iyy="3.77" iyz="0.0" 
                     izz="3.77" />
        </inertial>
        
        <visual>
            <origin rpy="1.57 0 1.57" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/base_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision>
            <origin rpy="1.57 0 1.57" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/base_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </collision>

    </link>

    <joint name="base_joint" type="fixed">

        <parent link="base_footprint" />
        <child link="base_link" />

        <origin rpy="0 0 0" xyz="0 0 0.1175" />

    </joint>

    <link name="wheel_right_link">

        <inertial>
            <mass value="0.836" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.00397" ixy="0.0" ixz="0.0"
                     iyy="0.00210" iyz="0.0" 
                     izz="0.00210" />
        </inertial>

        <visual>
            <origin rpy="0 0 1.57" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/wheel_right_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision>
            <origin rpy="0 0 1.57" xyz="0 -0.015 0" />
            <geometry>
                <sphere radius="0.0975" />
            </geometry>
        </collision>

    </link>

    <joint name="wheel_right_joint" type="continuous">

        <parent link="base_link" />
        <child link="wheel_right_link" />

        <axis xyz="0 1 0" />
        <origin rpy="0 0 0" xyz="0 -0.360 -0.020" />

    </joint>

    <link name="wheel_left_link">

        <inertial>
            <mass value="0.836" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.00397" ixy="0.0" ixz="0.0"
                     iyy="0.00210" iyz="0.0" 
                     izz="0.00210" />
        </inertial>

        <visual>
            <origin rpy="0 0 1.57" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/wheel_left_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision>
            <origin rpy="0 0 1.57" xyz="0 0.015 0" />
            <geometry>
                <sphere radius="0.0975" />
            </geometry>
        </collision>

    </link>

    <joint name="wheel_left_joint" type="continuous">

        <parent link="base_link" />
        <child link="wheel_left_link" />

        <axis xyz="0 1 0" />
        <origin rpy="0 0 0" xyz="0 0.360 -0.020" />

    </joint>

    <link name="caster_front_link">

        <inertial>
            <mass value="0.329" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.000306" ixy="0.0" ixz="0.0"
                     iyy="0.000306" iyz="0.0" 
                     izz="0.000306" />
        </inertial>

        <visual>
            <origin rpy="1.57 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/caster_wheel_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision>
            <origin rpy="1.57 0 0" xyz="0 0 0" />
            <geometry>
                <sphere radius="0.0965" />
            </geometry>
        </collision>

    </link>

    <joint name="caster_front_joint" type="fixed">

        <parent link="base_link" />
        <child link="caster_front_link" />

        <origin rpy="0 0 0" xyz="0.275 0 -0.021" />

    </joint>

    <link name="caster_rear_link">

        <inertial>
            <mass value="0.329" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.000306" ixy="0.0" ixz="0.0"
                     iyy="0.000306" iyz="0.0" 
                     izz="0.000306" />
        </inertial>

        <visual>
            <origin rpy="1.57 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/caster_wheel_link.stl" scale="0.001 0.001 0.001" />
            </geometry>
        </visual>

        <collision>
            <origin rpy="1.57 0 0" xyz="0 0 0" />
            <geometry>
                <sphere radius="0.0965" />
            </geometry>
        </collision>

    </link>

    <joint name="caster_rear_joint" type="fixed">

        <parent link="base_link" />
        <child link="caster_rear_link" />

        <origin rpy="0 0 0" xyz="-0.275 0 -0.021" />

    </joint>

    <link name="imu_link">

        <inertial>
            <origin xyz="-0.00552433659106688 0.000168210391520346 0.000514000497342681" rpy="0 0 0" />
            <mass value="0.000528415362211671" />
            <inertia ixx="1.46176048428261E-08" ixy="1.40015117949421E-10" ixz="-1.99633872937403E-12"
                    iyy="8.59662482954888E-09" iyz="7.52375112767959E-12"
                    izz="2.30279421279312E-08" />
        </inertial>
        
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/imu_link.STL" />
            </geometry>
        </visual>

        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <mesh filename="package://smartdumpster_description/meshes/imu_link.STL" />
            </geometry>
        </collision>

    </link>

    <joint name="imu_joint" type="fixed">
        
        <parent link="base_link" />
        <child link="imu_link" />

        <axis xyz="0 0 0" />
        <origin xyz="0 0 0.150" rpy="0 0 0" />

    </joint>

</robot>